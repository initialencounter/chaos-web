{
  "name": "tapsss-forum",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build:s": "vite build && bun build ./proxy-server.ts --compile --target=bun-linux-x64 --outfile ./tapsss-forum/app",
    "dev:s": "DEV=true bun --hot ./proxy-server.ts",
    "dev": "vite",
    "dev:full": "run-p dev dev:s",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@tapsss/forum-shared": "workspace:*",
    "@tapsss/shared": "workspace:*",
    "howler": "^2.2.4",
    "markdown-it": "^14.0.0",
    "pako": "^2.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tapsss/server": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/howler": "^2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.2.6"
  }
}
