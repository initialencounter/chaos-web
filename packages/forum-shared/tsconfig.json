{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "lib": ["esnext", "dom"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@tapsss/shared": ["../shared/src"],
      "@tapsss/shared/*": ["../shared/src/*"]
    },
    "resolveJsonModule": true,
    "strict": false,
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
