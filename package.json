{
  "name": "tapsss.initialencounter.chaos",
  "version": "0.1.1",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "description": "Vite + Electron with esbuild, so fast! ⚡",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:c": "cd ./tapsss-forum && vite",
    "dev:s": "TOP_DIR=true; DEV=true; bun --hot ./tapsss-forum/proxy-server.ts",
    "dev:full": "run-p dev:c dev:s",
    "dev": "rimraf dist && chcp 65001 && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:main && npm run test:render",
    "test:render": "vitest run -r src/render --passWithNoTests",
    "test:main": "vitest run -r src/main --passWithNoTests",
    "test:e2e": "vitest run",
    "postinstall": "npx simple-git-hooks && electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tapsss/forum-shared": "workspace:*",
    "@tapsss/server": "workspace:*",
    "@tapsss/shared": "workspace:*",
    "@vueuse/core": "^13.8.0",
    "element-plus": "^2.7.6",
    "howler": "^2.2.4",
    "markdown-it": "^14.1.0",
    "pako": "^2.1.0",
    "pinia": "^3.0.4",
    "sass": "~1.77.6",
    "vue": "^3.5.34",
    "vue-router": "^4.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "1.0.154",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/compiler-sfc": "3.5.34",
    "@vue/test-utils": "2.4.10",
    "baseline-browser-mapping": "^2.10.27",
    "electron": "42.0.0",
    "electron-builder": "26.8.1",
    "eslint": "10.3.0",
    "happy-dom": "20.9.0",
    "lint-staged": "17.0.2",
    "npm-run-all": "^4.1.5",
    "playwright": "1.59.1",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-plugin-doubleshot": "0.0.22",
    "vite-plugin-vue-devtools": "8.1.2",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.8"
  },
  "resolutions": {
    "@vue/compat": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "vue": "beta"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
