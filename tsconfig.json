{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/render/*"
      ],
      "@render/*": [
        "./src/render/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@common/*": [
        "./src/common/*"
      ],
      "@tapsss/shared": [
        "./packages/shared/src"
      ],
      "@tapsss/shared/*": [
        "./packages/shared/src/*"
      ],
      "@tapsss/server": [
        "./packages/server/src"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "vite/client",
      "./src/preload"
    ],
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ]
}
